<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Xóa Booking Thành Công</title>

<style>
*{
box-sizing:border-box;
font-family:Segoe UI, Tahoma, sans-serif;
}

body{
margin:0;
height:100vh;
display:flex;
align-items:center;
justify-content:center;
background:linear-gradient(135deg,#f5f7fa,#c3cfe2);
}

.card{
background:white;
padding:40px;
border-radius:12px;
box-shadow:0 10px 30px rgba(0,0,0,0.1);
text-align:center;
width:400px;
}

.icon{
font-size:60px;
color:#27ae60;
margin-bottom:15px;
}

h2{
margin:10px 0;
color:#2c3e50;
}

p{
color:#666;
margin-bottom:25px;
}

a{
text-decoration:none;
padding:10px 20px;
background:#3498db;
color:white;
border-radius:6px;
transition:0.2s;
}

a:hover{
background:#2980b9;
}
</style>

</head>

<body>

<div class="card">

<div class="icon">✔</div>

<h2>Xóa thành công</h2>

<p>Booking đã được xóa khỏi hệ thống.</p>

<a href="/bookings/view">Quay lại danh sách</a>

</div>

</body>
</html>